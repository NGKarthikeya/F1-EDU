  "regulations": [
    {
      "flag_color": "green",
      "flag_name": "Green Flag",
      "meaning": "An easy one to start with, the green flag is used to indicate that the track is clear and drivers can proceed – whether this is at the start of a warm-up lap, practice session or Qualifying, or immediately after an incident.",
      "animation_class": "flag-green",
      "bg_color": "#00a651",
      "text_color": "#0a0a0a",
      "scroll_order": 1
    },
    {
      "flag_color": "yellow",
      "flag_name": "Yellow Flag (Single Waved)",
      "meaning": "Simply put, the yellow flag is a signal of danger. Single waved: Drivers need to reduce their speed, cannot overtake and must be prepared to change direction, due to a hazard beside or partly on the track.",
      "animation_class": "flag-yellow",
      "bg_color": "#FFD700",
      "text_color": "#0a0a0a",
      "scroll_order": 2
    },
    {
      "flag_color": "double_yellow",
      "flag_name": "Yellow Flag (Double Waved)",
      "meaning": "Double waved: Drivers need to reduce their speed significantly, cannot overtake and must be prepared to change direction or stop, due to a hazard wholly or partly blocking the track and/or marshals working on or beside the track.",
      "animation_class": "flag-yellow",
      "bg_color": "#FFD700",
      "text_color": "#0a0a0a",
      "scroll_order": 3
    },
    {
      "flag_color": "safety",
      "flag_name": "Safety Car / VSC",
      "meaning": "If a variable speed limit is imposed, this is indicated with a single yellow flag and a board labelled 'VSC' (Virtual Safety Car). In some cases, a speed limit around a section of track may be imposed when double yellow flags are displayed.",
      "animation_class": "flag-safety",
      "bg_color": "#1a1a2e",
      "text_color": "#F5F5F5",
      "scroll_order": 4
    },
    {
      "flag_color": "red",
      "flag_name": "Red Flag",
      "meaning": "A red flag is waved when the Race Director decides to stop a session or race, with reasons ranging from a serious incident to poor weather conditions. All drivers must reduce speed and proceed slowly.",
      "animation_class": "flag-red",
      "bg_color": "#E8002D",
      "text_color": "#FFFFFF",
      "scroll_order": 5
    },
    {
      "flag_color": "blue",
      "flag_name": "Blue Flag",
      "meaning": "The blue flag is normally waved to inform a driver that they are about to be overtaken. During the race, it is shown to a driver who is about to be lapped. If three warnings are ignored, they will be penalised.",
      "animation_class": "flag-blue",
      "bg_color": "#0057B7",
      "text_color": "#FFFFFF",
      "scroll_order": 6
    },
    {
      "flag_color": "striped",
      "flag_name": "Yellow and Red Striped Flag",
      "meaning": "A motionless, striped yellow and red flag is shown to inform drivers that there has been a deterioration in grip levels on the track ahead, perhaps because of oil or water on the surface.",
      "animation_class": "flag-striped",
      "bg_color": "#FFD700",
      "text_color": "#0a0a0a",
      "scroll_order": 7
    },
    {
      "flag_color": "white",
      "flag_name": "White Flag",
      "meaning": "The white flag is waved to inform a driver that there is a much slower vehicle ahead, and is sometimes seen at the end of practice sessions while drivers are completing practice starts from the grid.",
      "animation_class": "flag-white",
      "bg_color": "#F5F5F5",
      "text_color": "#0a0a0a",
      "scroll_order": 8
    },
    {
      "flag_color": "half",
      "flag_name": "Black and White Flag",
      "meaning": "Not to be confused with the chequered flag, the diagonally-divided 'black and white flag' is shown as a warning to drivers that have been reported for unsportsmanlike behaviour, and that any more will result in punishment.",
      "animation_class": "flag-half",
      "bg_color": "#555555",
      "text_color": "#FFFFFF",
      "scroll_order": 9
    },
    {
      "flag_color": "meatball",
      "flag_name": "Black Flag with Orange Disc",
      "meaning": "The black flag with an orange circle is used to inform a driver that their car has mechanical problems which are likely to pose a danger to themselves or others, and they must stop in the pits as soon as possible.",
      "animation_class": "flag-meatball",
      "bg_color": "#111111",
      "text_color": "#FFFFFF",
      "scroll_order": 10
    },
    {
      "flag_color": "black",
      "flag_name": "Black Flag",
      "meaning": "The black flag is used to disqualify a driver and orders them to return to their garage at once. The decision to show this flag rests solely with the stewards. A driver being shown the black flag is a rare occurrence in F1.",
      "animation_class": "flag-black",
      "bg_color": "#111111",
      "text_color": "#FFFFFF",
      "scroll_order": 11
    },
    {
      "flag_color": "chequered",
      "flag_name": "Chequered Flag",
      "meaning": "The black and white chequered flag – waved from above the pit wall – marks the end of any session or race, and is waved until all competing cars have reached it.",
      "animation_class": "flag-chequered",
      "bg_color": "#DDDDDD",
      "text_color": "#111111",
      "scroll_order": 12
    }
  ],
