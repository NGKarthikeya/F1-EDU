  "qualifying_rules": [
    {
      "era_start": 1950,
      "era_end": 1995,
      "format_name": "Two 1-Hour Sessions",
      "description": "Drivers had two separate one-hour qualifying sessions on Friday and Saturday. The single fastest lap across both sessions granted pole position. This format rewarded drivers who could put in a perfect single lap under low fuel loads, but the best time could come from either day.",
      "sort_order": 1
    },
    {
      "era_start": 2003,
      "era_end": 2005,
      "format_name": "Single-Lap Elimination",
      "description": "Each driver went out alone for exactly one flying lap. Order was determined by championship standings (worst first). Under race fuel loads, this made the lap incredibly strategic — any mistake ended your chance. Widely criticised for poor TV spectacle and dropped after 2005.",
      "sort_order": 2
    },
    {
      "era_start": 2006,
      "era_end": 2020,
      "format_name": "Knockout Q1 / Q2 / Q3",
      "description": "The current format introduced in 2006. Q1 (18 min): 5 slowest cars eliminated. Q2 (15 min): next 5 eliminated. Q3 (12 min): top 10 shootout for pole. Cars knocked out in Q2 must start on the tyre set that achieved their fastest Q2 lap — creating strategic implications for the race.",
      "sort_order": 3
    },
    {
      "era_start": 2021,
      "era_end": null,
      "format_name": "Sprint Weekends (Hybrid)",
      "description": "Select rounds feature a 100km Sprint race on Saturday. The Sprint grid is set by a shorter Qualifying Shootout on Friday. Sprint finishes award points (8–1) and in some formats set the Sunday race grid. Highly controversial — purists argue it removes the purity of qualifying as a pure time-trial.",
      "sort_order": 4
    }
  ],
  "era_regulations": [
    {
      "era_start": 1994,
      "era_end": 2009,
      "label": "Refueling Era",
      "refueling_allowed": 1,
      "avg_pit_seconds": 8.5,
      "mandatory_stops": 1,
      "description": "Mid-race refueling was permitted. Strategy revolved around fuel weight — a lighter car is dramatically faster. Teams could run fewer laps on heavy fuel then sprint after a refuel. Pit stops averaged 7–12 seconds. Banned in 2010 due to safety concerns (a fire during refueling at Benetton 1994) and to reduce costs."
    },
    {
      "era_start": 2010,
      "era_end": null,
      "label": "Tyre-Only Era",
      "refueling_allowed": 0,
      "avg_pit_seconds": 2.4,
      "mandatory_stops": 1,
      "description": "Refueling banned from 2010. Cars must start with all fuel needed for the entire race — typically 110kg. Pit stops became pure tyre changes, dropping times to 2–3 seconds (Red Bull achieved a 1.82s record in 2023). Mandatory rule: drivers must use at least two different dry tyre compounds (Soft, Medium, or Hard) per race, forcing at least one stop in dry conditions."
    }
